<mvc:View controllerName="dev2026.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <ComboBox id="currencyComboBox"
            change=".onFiltrarPorMoneda"
            showClearIcon="true"
            showSecondaryValues="true"
            filterSecondaryValues="true"
            items="{
                path: 'localCurrencies>/Currencies',
                sorter: { path: 'currencyName' }
            }">
            <core:ListItem id="_IDGenListItem"
                key="{localCurrencies>currencyCode}"
                text="{localCurrencies>currencyName}"
                additionalText="{localCurrencies>currencyCode}"/>
        </ComboBox>

        <!-- La tabla, con SUS columnas e items, sin nada ajeno en medio -->
        <Table id="currencyTable"
            items="{/ZC_FV_CURR}"
            growing="true"
            growingThreshold="20">
            <columns>
                <Column id="_IDGenColumn"><Text id="_IDGenText1" text="Moneda"/></Column>
                <Column id="_IDGenColumn1"><Text id="_IDGenText2" text="Símbolo"/></Column>
                <Column id="_IDGenColumn2"><Text id="_IDGenText3" text="Region"/></Column>
                <Column id="_IDGenColumn3"><Text id="_IDGenText4" text="Tasa USD"/></Column>
                <Column id="_IDGenColumn4"><Text id="_IDGenText5" text="Estado"/></Column>
                <Column id="_IDGenColumn5"><Text id="_IDGenText6" text="Last Sync"/></Column>
            </columns>
            <items>
                <ColumnListItem id="_IDGenColumnListItem" type="Navigation" press=".onFilaPulsada">
                    <cells>
                        <ObjectIdentifier id="_IDGenObjectIdentifier" title="{Waers}" text="{Name}"/>
                        <Text id="_IDGenText7" text="{Simbol}"/>
                        <Text id="_IDGenText8" text="{Region}"/>
                        <Text id="_IDGenText9" text="{
                            path: 'TasaUsd',
                            type: 'sap.ui.model.type.Float',
                            formatOptions: { minFractionDigits: 2, maxFractionDigits: 2 }
                        }"/>
                        <core:Icon id="_IDGenIcon"
                            src="{path: 'Status', formatter: '.formatter.formatStatusIcon'}"
                            color="{path: 'Status', formatter: '.formatter.formatStatusColor'}"/>
                        <Text id="_IDGenText10" text="{
                            path: 'LastSync',
                            type: 'sap.ui.model.type.Date',
                            formatOptions: { UTC: true, pattern: 'dd.MM.yyyy' }
                        }"/>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
  <footer>
    <OverflowToolbar id="_IDGenOverflowToolbar">
        <Button id="_IDGenButton1" text="Cargar Datos" type="Accept" press=".onLoadData"/>
        <Button id="_IDGenButton2" text="Obtener Tasa USD" type="Reject" press=".onGetRateUSD"/>
        <ToolbarSpacer id="_IDGenToolbarSpacer"/>
        <Button id="_IDGenButton3" text="Navegar a Smart View" type="Emphasized" press=".onNavToSmartView"/>
    </OverflowToolbar>
</footer>
    </Page>
</mvc:View>